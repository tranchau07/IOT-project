@startuml
title Backend MQTT Inbound Processing Pipeline

start

:Receive MQTT message;
:Extract topic & payload;

if (JSON valid?) then (Yes)
    :Extract deviceId from topic;
else (No)
    :Log malformed JSON;
    stop
endif


if (Topic = SENSOR_DATA?) then (Yes)

    :Parse sensor payload;
    :Create SensorData entity;
    :Save to MongoDB;

elseif (Topic = STATUS?) then (Yes)

    :Parse status payload;
    :Find device in MySQL;

    if (Device exists?) then (Yes)
        :Update device.status;
        :Update lastCommunication;
        :Save to MySQL;
    else (No)
        :Log device not found;
    endif

elseif (Topic = CONTROL_RESPONSE?) then (Yes)

    :Parse control response;
    :Find command in MySQL;

    if (Command exists?) then (Yes)
        :Update command status;
        :Save to MySQL;
    else (No)
        :Log command not found;
    endif

else
    :Log unknown topic;
endif

:Processing complete;
stop

@enduml
