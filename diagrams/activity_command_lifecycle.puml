@startuml
title Command Lifecycle (Based on Actual Implementation)

start
:User taps ON/OFF button;

partition "App - Send Request" {
    :Create CommandRequest;
    :POST /api/devices/{id}/on or /off;
}

partition "Backend - Validate & Create Command" {

    if (DeviceId valid?) then (Yes)
        :Create Command (status=PENDING);
        :Save to MySQL;
        :Call sendControlCommand();
    else (No)
        :Return HTTP 400;
        stop
    endif
}

partition "Backend - Publish MQTT" {
    :Build MQTT payload {commandId, command};
    :Update status = SENT;
    :Publish to topic devices/{id}/control (QoS 1);
}

partition "Device - Execute" {

    :Receive control message;
    :Parse JSON;

    if (JSON valid?) then (Yes)

        if (command == ON?) then (Yes)
            :digitalWrite HIGH;
        else (No)
            :digitalWrite LOW;
        endif

        :Prepare SUCCESS response;

    else (No)
        :Prepare FAILED response;
    endif

    :Publish response to
    devices/{id}/control/response;
}

partition "Backend - Handle Response" {

    :Receive MQTT response;
    :Parse payload;

    if (Command exists?) then (Yes)
        :Update status = COMPLETED or FAILED;
        :Save to MySQL;
    else (No)
        :Log orphaned response;
    endif
}

partition "App - UI Update" {

    if (User refreshes / re-renders?) then (Yes)
        :GET latest device state;
        :Update UI accordingly;
    else (No)
        :UI remains unchanged;
    endif
}

:Command lifecycle complete;
stop

@enduml
