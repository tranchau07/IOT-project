@startuml
title App User Flow (REST Only)

start
:Open React Native App;

partition "Authentication Check" {

    :Check AsyncStorage for saved JWT;

    if (Token exists?) then (Yes)
        :Decode JWT;
        :Set isAuthenticated = true;
    else (No)
        :Set isAuthenticated = false;
    endif
}

if (isAuthenticated?) then (Yes)

    partition "Main App" {

        :Render HomeScreen;
        :Call GET /api/devices;

        if (HTTP 200?) then (Yes)
            :Store device list in state;
        elseif (HTTP 401?) then (Yes)
            :Clear token;
            :Navigate to LoginScreen;
            stop
        else
            :Show error notification;
        endif

        repeat
            :User interacts with UI;

            if (Tap device card?) then (Yes)
                :Open DeviceDetailScreen;

            elseif (Tap control button?) then (Yes)

                :POST /api/devices/{id}/on or /off;

                if (HTTP 202?) then (Yes)
                    :Show temporary notification;
                    :User refreshes screen or component re-renders;
                    :Call GET /api/devices/{id};
                    :Update UI based on latest state;
                else
                    :Show request error;
                endif

            elseif (Pull to refresh?) then (Yes)
                :Call GET /api/devices;
                :Update device list;

            elseif (Logout?) then (Yes)
                :Remove token from AsyncStorage;
                :Set isAuthenticated = false;
                :Navigate to LoginScreen;
                stop
            endif

        repeat while (App running?)

    }

else (No)

    partition "Login Flow" {

        :Render LoginScreen;
        :User enters credentials;
        :POST /identity/api/auth/login;

        if (HTTP 200?) then (Yes)
            :Extract JWT;
            :Save token to AsyncStorage;
            :Set isAuthenticated = true;
            :Navigate to HomeScreen;
        elseif (HTTP 401?) then (Yes)
            :Show invalid credentials message;
        else
            :Show network error;
        endif
    }

endif

stop
@enduml
