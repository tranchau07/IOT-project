@startuml
title Sensor Data Publishing (Every 5 Seconds)

participant "ESP32 Device" as Device
participant "MQTT Broker" as Broker
participant "Inbound Handler Service" as Service
participant "MongoDB" as DB
participant "WebSocket Gateway" as WS
participant "React Native App" as App

autonumber

loop Every 5 seconds (while isActive == true)

    Device -> Broker: PUBLISH sensors/{deviceId}/data
    note right
    Payload: {temperature, humidity, timestamp}
    QoS 1
    end note

    Broker -> Service: Deliver MQTT message
    activate Service

    Service -> Service: Parse & validate payload

    alt Valid data
        Service -> DB: INSERT sensor_data
        activate DB
        DB -->> Service: OK
        deactivate DB

        Service -> Service: Update device last_activity

        opt Real-time update enabled
            Service -> WS: Push sensor update
            WS -> App: SENSOR_UPDATE event
            activate App
            App -> App: Re-render UI
            deactivate App
        end

    else Invalid data
        Service -> Service: Log & discard
    end

    deactivate Service

end

@enduml
