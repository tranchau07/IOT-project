@startuml
title Device Internal Loop / Lifecycle (ESP32)

start
:Boot;
:Initialize hardware (GPIO, sensors);
:Load WiFi credentials;

partition "WiFi Connection" {
    repeat
        :Attempt WiFi connect;
        :Delay 500ms;
    repeat while (Connected?) is (No)

    :WiFi Connected;
}

:Start NTP client;
:Sync system time;

partition "MQTT Connection" {
    repeat
        :Attempt MQTT connect;
        :Exponential backoff delay;
    repeat while (MQTT connected?) is (No)

    :Subscribe to control & status topics;
}

partition "Main Loop" {

    repeat

        partition "Sensor Publishing" {

            if (isActive == TRUE?) then (Yes)
                :Read sensor values;
                :Create JSON payload;
                :Publish to sensors topic;
            else (No)
                :Skip publishing;
            endif

            :Wait 5 seconds;
        }

        partition "Incoming Message Handler" {

            if (MQTT message received?) then (Yes)

                if (JSON valid?) then (Yes)

                    if (Control topic?) then (Yes)

                        if (Command valid?) then (Yes)
                            :Execute action (LED ON/OFF);
                            :Create SUCCESS response;
                        else (No)
                            :Create FAILED response;
                        endif

                        :Publish control/response;

                    elseif (Status topic?) then (Yes)

                        if (Status == ACTIVE?) then (Yes)
                            :Set isActive = TRUE;
                        else (No)
                            :Set isActive = FALSE;
                        endif

                    else
                        :Ignore unknown topic;
                    endif

                else (No)
                    :Log parse error;
                endif

            else (No)
                :No incoming message;
            endif
        }

        partition "Reconnection Check" {

            if (MQTT connection lost?) then (Yes)

                repeat
                    :Attempt reconnect;
                    :Backoff delay;
                repeat while (MQTT connected?) is (No)

                :Re-subscribe topics;

            else (No)
                :Connection healthy;
            endif
        }

    repeat while (Power ON?) is (Yes)

}

:Power off;
stop

@enduml